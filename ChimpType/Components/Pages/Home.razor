@page "/"
@inject TextService TextService
@inject TestsDataService TestDataService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Home</PageTitle>

<div class="typing-page">
    <h1 class="welcome-text">Welcome to ChimpType! A monkey type clone!</h1>
    <div class="typing-game-container">
        <div class="control-buttons-container">
            <MudTooltip Text="Repeat test">
                <MudIconButton Icon="@Icons.Material.Filled.Refresh" aria-label="Repeat test" OnClick="ResetTyping" />
            </MudTooltip>
            <MudTooltip Text="Next test">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowForward" aria-label="Next test" OnClick="StartNextTest" />
            </MudTooltip>
            <MudTooltip Text="Top charts">
                <MudIconButton Icon="@Icons.Material.Filled.TableChart" aria-label="Top charts" OnClick="GoToTopCharts" />
            </MudTooltip>
        </div>
        @if (!_showReport)
        {
            <div class="type-area" 
            @onfocus="TypeAreaFocused" 
            @onblur="TypeAreaBlured" 
            @onkeydown="OnKeystrokeTypeArea" 
            tabindex="0"
            @onclick="() => _divElement.FocusAsync()" 
            @ref="_divElement">

                <div style="height: 1em;">
                    @if (_isTimerGoing)
                    {
                        @if (Test.TestType == TestType.Words || Test.TestType == TestType.Quote)
                        {
                            <span style="color: #fcba03;">@Test.WordsFinished.Count/@Test.WordsToComplete</span>
                        }
                        else
                        {
                            <span style="color: #fcba03;">@_elapsedTime.Minutes.ToString("00"):@_elapsedTime.Seconds.ToString("00")</span>
                        }
                    }
                </div>
                <p class="text-container" @ref="_textContainer">
                    @for(var i = 0; i < Test.Buffer.Text.Length; i++)
                    {
                        <span @key="i" class="@GetLetterStyle(Test.Buffer.Styles[i]) @(_currentIndex == i && _isFocused ? "cursor" : "") letter">@Test.Buffer.Text[i]</span>
                    }
                </p>
            </div>
            @if (Test.TestType == TestType.Zen)
            {
                <span style="justify-self: center; text-align: center; display: flex;">Press Enter to finish Zen and get your report</span>
            }
        }
        else
        {
            <div class="typing-report">
                <div class="numeric-stats-container">
                    <span>Final time: @Report.FinalTime.Minutes.ToString("00"):@Report.FinalTime.Seconds.ToString("00")</span>
                    <MudTooltip Text="Words per minute">
                        <span style="display: block; height: auto;">WPM: @Report.WPM</span>
                    </MudTooltip>
                    <span>Accuracy: @Report.Accuracy%</span>
                    <MudTooltip Text="Correct/Incorrect/Extra/Missed">
                        <span>@Report.CorrectChars/@Report.IncorrectChars/@Report.ExtraChars/@Report.MissedChars</span>
                    </MudTooltip>
                </div>
                <MudPaper Class="pa-6 ma-4">
                    <MudChart ChartType="ChartType.Line" ChartSeries="@_series" ChartLabels="@_axisLabels" Width="100%" Height="350px" MatchBoundsToSize="true" ChartOptions="@_options" />
                </MudPaper>
            </div>
        }
        
        @if (!_isTimerGoing && !_showReport)
        {
            <div class="test-type-switches">
                <div class="test-types">
                    <MudText Style="color:#fcba03;">Test type</MudText>
                    <MudButtonGroup OverrideStyles="false">
                        @foreach (var testType in Enum.GetNames(typeof(TestType)))
                        {
                            <MudButton Color="Color.Primary" Variant="@GetTestTypeSwitchVariant(testType)" OnClick="@(() => OnTestTypeSelected(testType))">@testType</MudButton>
                        }
                    </MudButtonGroup>
                </div>
                @if (Test.TestType == TestType.Words)
                {
                    <div class="test-types">
                        <MudText Style="color:#fcba03;">Word count</MudText>
                        <MudButtonGroup Class="my-button-group" OverrideStyles="false">
                            <MudButton Color="Color.Primary" Variant="@GetWordCountSwitchVariant(10)" OnClick="@(() => OnWordCountSelected(10))">10</MudButton>
                            <MudButton Color="Color.Primary" Variant="@GetWordCountSwitchVariant(25)" OnClick="@(() => OnWordCountSelected(25))">25</MudButton>
                            <MudButton Color="Color.Primary" Variant="@GetWordCountSwitchVariant(50)" OnClick="@(() => OnWordCountSelected(50))">50</MudButton>
                            <MudButton Color="Color.Primary" Variant="@GetWordCountSwitchVariant(100)" OnClick="@(() => OnWordCountSelected(100))">100</MudButton>
                        </MudButtonGroup>
                    </div>
                }
                @if (Test.TestType == TestType.Time)
                {
                    <div class="test-types">
                        <MudText Style="color:#fcba03;">Time span</MudText>
                        <MudButtonGroup OverrideStyles="false">
                            <MudButton Color="Color.Primary" Variant="@GetTimeSpanSwitchVarian(15)" OnClick="@(() => OnTimeSpanSelected(15))">15</MudButton>
                            <MudButton Color="Color.Primary" Variant="@GetTimeSpanSwitchVarian(30)" OnClick="@(() => OnTimeSpanSelected(30))">30</MudButton>
                            <MudButton Color="Color.Primary" Variant="@GetTimeSpanSwitchVarian(60)" OnClick="@(() => OnTimeSpanSelected(60))">60</MudButton>
                            <MudButton Color="Color.Primary" Variant="@GetTimeSpanSwitchVarian(120)" OnClick="@(() => OnTimeSpanSelected(120))">120</MudButton>
                        </MudButtonGroup>
                    </div>
                }
                @if (Test.TestType == TestType.Quote)
                {
                    <div class="test-types">
                        <MudText Style="color:#fcba03;">Quote length</MudText>
                        <MudButtonGroup OverrideStyles="false">
                            @foreach (var length in Enum.GetNames(typeof(QuoteLength)))
                            {
                                <MudButton Color="Color.Primary" Variant="@GetQuoteLengthSwitchVariant(length)" OnClick="@(() => OnQuoteLengthSelected(length))">@length</MudButton>
                            }
                        </MudButtonGroup>
                    </div>
                }
            </div>
        }
    </div>
</div>

<script>
    function scrollToCursorPosition(container, index) {

        const letters = container.querySelectorAll('.letter');
        if (letters[index]) {
            const letterRect = letters[index].getBoundingClientRect();
            const containerRect = container.getBoundingClientRect();

            // Scroll so cursor letter is at TOP of container
            const middleOffset = containerRect.height / 2;
            container.scrollTop = letters[index].offsetTop - middleOffset +
                                 letters[index].offsetHeight / 2;
        }
    }

    function scrollToTop(container) {
        container.scrollTop = 0;
    }
</script>

@code {
    [CascadingParameter] private Task<AuthenticationState> authenticationStateTask { get; set; } = default!;
    private AuthenticationState? _context;

    private string _timerText = "00:00";
    private int _currentIndex = 0;
    private bool _isFocused = false;
    private bool _isTimerGoing = false;
    private bool _showReport = false;
    private Timer? _typingTimer;
    private DateTime _startTime;
    private TimeSpan _elapsedTime = TimeSpan.Zero;
    private ElementReference _divElement;
    private ElementReference _textContainer;

    private ReportModel Report = new();
    private TestModel Test = new();
    private string[] _axisLabels = { };
    private List<ChartSeries<double>> _series = new();
    private LineChartOptions _options = new();

    protected override async Task OnInitializedAsync()
    {
        GetNewText();
        _options.InterpolationOption = InterpolationOption.NaturalSpline;
        _options.YAxisFormat = "c2";
        _context = await authenticationStateTask;
    }

    private void TypeAreaFocused(FocusEventArgs args)
    {
        _isFocused = true;
    }

    private void TypeAreaBlured(FocusEventArgs args)
    {
        _isFocused = false;
    }

    private string GetLetterStyle(LetterStyle letterStyle)
    {
        switch (letterStyle)
        {
            case LetterStyle.Correct:
                return "correct-letter";
            case LetterStyle.ToType:
                return "letter-to-type";
            case LetterStyle.Wrong:
                return "wrong-letter";
            case LetterStyle.Extra:
                return "wrong-letter";
            default:
                return "letter-to-type";
        }
    }

    private void OnTimerElapsed()
    {
        _elapsedTime = _isTimerGoing? DateTime.Now - _startTime : TimeSpan.Zero;
        if (Test.TestType == TestType.Time && _elapsedTime.TotalSeconds >= Test.TimeSeconds)
            FinishTypingTest();

        InvokeAsync(StateHasChanged);
    }

    private async Task OnIndexChanged()
    {
        await Task.Delay(1);
        await ScrollCursorToTop();
    }

    private async Task ScrollCursorToTop()
    {
        if (_currentIndex < Test.Buffer.Text.Length)
        {
            var cursorElement = _textContainer;
            var dotNetHelper = DotNetObjectReference.Create(this);

            await JS.InvokeVoidAsync("scrollToCursorPosition", _textContainer, _currentIndex);
        }
    }

    private void StartTypingTest()
    {
        _startTime = DateTime.Now;
        _isTimerGoing = true;
        _typingTimer = new Timer(_ => OnTimerElapsed(), null, 0, 1000);
    }

    private void FinishTypingTest()
    {
        _typingTimer?.Dispose();
        _isTimerGoing = false;
        CreateTypingReport();
    }

    private async Task OnKeystrokeTypeArea(KeyboardEventArgs args)
    {
        if (_currentIndex == Test.Buffer.Text.Length) return;

        if (args.Key.Length == 1) // Letter keys
        {
            if (_currentIndex == 0 && !_isTimerGoing)
            {
                StartTypingTest();
            }

            if (args.Key[0] == Test.Buffer.Text[_currentIndex])
            {
                Test.Buffer.Styles[_currentIndex] = LetterStyle.Correct;
                Test.Buffer.CharacterClicks.Add(DateTime.UtcNow);
                if (args.Key == " ") Test.WordsFinished.Add(DateTime.UtcNow);
            }
            else
            {

                if (Test.Buffer.Text[_currentIndex] == ' ')
                {
                    Test.Buffer.Text = Test.Buffer.Text.Insert(_currentIndex, args.Key);
                    Test.Buffer.Styles.Insert(_currentIndex, LetterStyle.Extra);
                }
                else
                {
                    Test.Buffer.Styles[_currentIndex] = LetterStyle.Wrong;
                }

                Test.Buffer.CharacterClicks.Add(DateTime.UtcNow);
                Test.Mistakes.Add(DateTime.Now);
            }

            _currentIndex++;
            await OnIndexChanged();
        }
        else // Non-letter keys (e.g., Backspace, Enter)
        {
            if (args.Key == "Backspace")
            {
                if (_currentIndex != 0)
                {
                    _currentIndex--;
                    await OnIndexChanged();

                    if (Test.Buffer.Styles[_currentIndex] == LetterStyle.Correct || Test.Buffer.Styles[_currentIndex] == LetterStyle.Wrong)
                    {
                        Test.Buffer.Styles[_currentIndex] = LetterStyle.ToType;
                        if (Test.Buffer.Text[_currentIndex] == ' ')
                        {
                            Test.WordsFinished.RemoveAt(Test.WordsFinished.Count - 1);
                        }
                    }
                    else if (Test.Buffer.Styles[_currentIndex] == LetterStyle.Extra)
                    {
                        Test.Buffer.Styles.RemoveAt(_currentIndex);
                        Test.Buffer.Text = Test.Buffer.Text.Remove(_currentIndex, 1);
                    }

                    Test.Buffer.CharacterClicks.RemoveAt(Test.Buffer.CharacterClicks.Count - 1);
                }
            }
            else if (args.Key == "Enter")
            {
                FinishTypingTest();
            }
        }

        if (_currentIndex == Test.Buffer.Text.Length && (Test.TestType == TestType.Quote || Test.TestType == TestType.Words))
        {
            FinishTypingTest();
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task CreateTypingReport()
    {
        var typedCharacters = Test.Buffer.Styles.Count(x => x != LetterStyle.ToType);
        Report.WPM = (int)Math.Round((typedCharacters / (double)5) / _elapsedTime.TotalMinutes);
        Report.Accuracy = Math.Round(100.0 - (((double)Test.Mistakes.Count / Test.Buffer.Text.Length) * 100), 2);
        Report.FinalTime = _elapsedTime;

        Report.CorrectChars = Test.Buffer.Styles.Count(x => x == LetterStyle.Correct);
        Report.IncorrectChars = Test.Buffer.Styles.Count(x => x == LetterStyle.Wrong);
        Report.ExtraChars = Test.Buffer.Styles.Count(x => x == LetterStyle.Extra);

        FormatPerformanceChart(typedCharacters);

        if (_context.User != null && _context.User.Identity.IsAuthenticated)
        {
            await SaveUserScore();
        }
        _showReport = true;
        await InvokeAsync(StateHasChanged);
    }

    private void FormatPerformanceChart(int typedCharacters)
    {
        _options.XAxisTitle = "Time";
        _options.YAxisTitle = "WPM";
        _options.YAxisFormat = "0";
        _options.YAxisToStringFunc = p => $"{p:0}";
        _options.YAxisTicks = 10;
        var totalSeconds = (int)Math.Round(Report.FinalTime.TotalSeconds);
        var targetTicks = 10;
        var tickSpacing = Math.Max(1, totalSeconds / targetTicks);

        _axisLabels = new string[totalSeconds];
        var series = new ChartSeries<double>();
        var wpmOverTime = new double[totalSeconds];
        for (var i = 0; i < totalSeconds; i++)
        {
            _axisLabels[i] = (i % tickSpacing == 0) ? $"{i}" : "";
            var clicksInTimeSpan = Test.Buffer.CharacterClicks.Count(x => x - _startTime < TimeSpan.FromSeconds(i + 1));
            var wpmInTimeSpan = (int)Math.Round((clicksInTimeSpan / (double)5) / ((i + 1) / (double)60));
            wpmOverTime[i] = wpmInTimeSpan;
        }
        series.Name = "WPM";
        series.Data = wpmOverTime;
        _series.Clear();
        _series.Add(series);
    }

    private TextBuffer ConvertStringToDisplay(string str)
    {
        var letters = new TextBuffer(str);

        for (var i = 0; i < letters.Text?.Length; i++)
        {
            letters.Styles[i] = LetterStyle.ToType;
        }

        return letters;
    }

    private async Task ResetTyping()
    {
        for (var i = 0; i < Test.Buffer?.Text?.Length; i++)
        {
            Test.Buffer.Styles[i] = LetterStyle.ToType;
        }

        _currentIndex = 0;
        _isTimerGoing = false;
        _showReport = false;
        Test.Buffer.CharacterClicks.Clear();
        Test.Mistakes.Clear();
        Test.WordsFinished.Clear();
        StateHasChanged();

        await Task.Delay(100);

        await JS.InvokeVoidAsync("scrollToTop", _textContainer);

    }

    private void GoToTopCharts()
    {
        Navigation.NavigateTo("/topcharts");
    }

    private async Task StartNextTest()
    {
        await ResetTyping();
        GetNewText();
    }

    private void GetNewText()
    {
        var typeText = string.Empty;
        switch(Test.TestType)
        {
            case TestType.Time:
                typeText = TextService.GetRandomWords(1000);
                break;
            case TestType.Quote:
                typeText = TextService.GetQuote(Test.QuoteLength);
                break;
            case TestType.Words:
                typeText = TextService.GetRandomWords(Test.WordCount);
                break;
            case TestType.Zen:
                typeText = TextService.GetRandomWords(3000);
                break;
        }
        Test.WordsToComplete = typeText.Split(' ', StringSplitOptions.RemoveEmptyEntries).Length;
        Test.Buffer = ConvertStringToDisplay(typeText);
        GC.Collect();
        StateHasChanged();
    }

    private Variant GetTestTypeSwitchVariant(string testType)
    {
        TestType testTypeEnum = Enum.Parse<TestType>(testType);
        if (Test.TestType == testTypeEnum)
        {
            return Variant.Filled;
        }
        return Variant.Outlined;
    }

    private void OnTestTypeSelected(string testType)
    {
        if (Enum.Parse<TestType>(testType) != Test.TestType)
        {
            Test.TestType = Enum.Parse<TestType>(testType);
            GetNewText();
            StateHasChanged();
        }
    }

    private Variant GetWordCountSwitchVariant(int wordCount)
    {
        if (Test.WordCount == wordCount)
        {
            return Variant.Filled;
        }

        return Variant.Outlined;
    }

    private void OnWordCountSelected(int wordCount)
    {
        if (Test.WordCount != wordCount)
        {
            Test.WordCount = wordCount;
            GetNewText();
            StateHasChanged();
        }
    }

    private Variant GetTimeSpanSwitchVarian(int timeSpan)
    {
        if (Test.TimeSeconds == timeSpan)
        {
            return Variant.Filled;
        }

        return Variant.Outlined;
    }

    private void OnTimeSpanSelected(int timeSpan)
    {
        if (Test.TimeSeconds != timeSpan)
        {
            Test.TimeSeconds = timeSpan;
            GetNewText();
            StateHasChanged();
        }
    }

    private Variant GetQuoteLengthSwitchVariant(string quoteLength)
    {
        var lengthEnum = Enum.Parse<QuoteLength>(quoteLength);
        if (Test.QuoteLength == lengthEnum)
        {
            return Variant.Filled;
        }

        return Variant.Outlined;
    }

    private void OnQuoteLengthSelected(string quoteLength)
    {
        if (Test.QuoteLength != Enum.Parse<QuoteLength>(quoteLength))
        {
            Test.QuoteLength = Enum.Parse<QuoteLength>(quoteLength);
            GetNewText();
            StateHasChanged();
        }
    }

    private async Task SaveUserScore()
    {
        var testType = string.Empty;
        switch (Test.TestType)
        {
            case TestType.Quote:
                testType = $"{Test.TestType.ToString()}:{Test.QuoteLength.ToString()}";
                break;
            case TestType.Time:
                testType = $"{Test.TestType.ToString()}:{Test.TimeSeconds}";
                break;
            case TestType.Words:
                testType = $"{Test.TestType.ToString()}:{Test.WordCount}";
                break;
            case TestType.Zen:
                testType = $"{Test.TestType.ToString()}:{Test.WordsFinished}:{Report.FinalTime.ToString("c")}";
                break;
        }
        var result = await TestDataService.InsertTestResult(_context.User.Identity.Name, Report.WPM, Report.Accuracy, testType, Test.Mistakes.Count, Report.CorrectChars, Report.MissedChars, Report.IncorrectChars, Report.ExtraChars, (int)Math.Round(Report.FinalTime.TotalSeconds));
    }

    public sealed class TextBuffer
    {
        public string? Text { get; set; }
        public List<LetterStyle> Styles { get; set; }
        public List<DateTime> CharacterClicks { get; set; }

        public TextBuffer(string text)
        {
            Text = text;
            Styles = new();
            foreach (var c in text)
            {
                Styles.Add(LetterStyle.ToType);
            }
            CharacterClicks = new();
        }

        public char this[int index] => Text[index];
    }

    public enum LetterStyle
    {
        Correct,
        Wrong,
        ToType,
        Extra
    }

    public enum TestType
    {
        Words,
        Quote,
        Time,
        Zen
    }

    public class ReportModel
    {
        public int WPM { get; set; }
        public double Accuracy { get; set; }
        public TimeSpan FinalTime { get; set; }
        public int CorrectChars { get; set; }
        public int IncorrectChars { get; set; }
        public int ExtraChars { get; set; }
        public int MissedChars { get; set; }
    }

    public class TestModel
    {
        public List<DateTime> Mistakes { get; set; } = new();
        public List<DateTime> WordsFinished { get; set; } = new();
        public TextBuffer? Buffer { get; set; }
        public TestType TestType { get; set; } = TestType.Time;
        public int TimeSeconds { get; set; } = 15;
        public int WordCount { get; set; } = 50;
        public int WordsToComplete { get; set; } = 0;
        public QuoteLength QuoteLength { get; set; } = QuoteLength.Mid;
    }
}